# Frontend (Next.js)
# Point these to your backend /server
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
# Demo switch: set to 1 to force mock providers and skip auth/login.
NEXT_PUBLIC_DEMO=0
# Public URL for "App real" link shown in demo banner.
NEXT_PUBLIC_REAL_APP_URL=https://diavlo-cord.vercel.app

# Optional: enables live GIF/sticker search in chat picker (server-side)
GIPHY_API_KEY=

# Optional: media generation popup (image/video)
# Foto: Civitai epiCRealism XL by default if CIVITAI_API_TOKEN exists
# (falls back to Wavespeed SD3.5 if IMAGE_GENERATION_PROVIDER=wavespeed)
# Video: WAN 2.2 (set WAN22_WORKFLOW_ENDPOINT to your Kijai wrapper endpoint if needed)
IMAGE_GENERATION_PROVIDER=auto
WAVESPEED_API_KEY=
WAVESPEED_API_BASE_URL=https://api.wavespeed.ai/api/v3
WAVESPEED_SD35_ENDPOINT=stability-ai/stable-diffusion-3.5-large
WAN22_WORKFLOW_ENDPOINT=wavespeed-ai/wan-2.2/i2v-720p-ultra-fast
# Optional: per-quality video endpoints. If empty, all qualities use WAN22_WORKFLOW_ENDPOINT.
# WAN22_WORKFLOW_ENDPOINT_LOW=
# WAN22_WORKFLOW_ENDPOINT_STANDARD=
# WAN22_WORKFLOW_ENDPOINT_ULTRA=

CIVITAI_API_TOKEN=
CIVITAI_IMAGE_MODEL_URL=https://civitai.com/models/277058/epicrealism-xl
# Optional: pin specific model version id from Civitai API
# CIVITAI_IMAGE_MODEL_VERSION_ID=
CIVITAI_ORCHESTRATION_URL=https://orchestration.civitai.com
