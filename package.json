{
  "name": "discord-clone",
  "version": "0.1.0",
  "description": "DiavloCord desktop and web client",
  "author": {
    "name": "Nikolai-coder",
    "email": "nijigon2001@gmail.com"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently -n web,server -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "check:all": "node scripts/check-all.mjs",
    "check:apps": "npm run desktop:build:dir",
    "media:check:ffmpeg": "node scripts/check-ffmpeg.mjs",
    "backend:check": "node scripts/check-backend.mjs",
    "media:encode:login": "node scripts/encode-login-video.mjs",
    "start": "next start",
    "lint": "npm run typecheck",
    "lint:a11y": "eslint --config eslint.a11y.config.mjs \"src/**/*.{ts,tsx}\"",
    "a11y": "npm run lint:a11y && npm run typecheck",
    "desktop:dev": "npm run desktop:icon && cross-env DIAVLOCORD_DESKTOP_URL=http://localhost:3000 electron ./desktop/main.cjs",
    "desktop:app": "npm run desktop:icon && cross-env DIAVLOCORD_DESKTOP_URL=https://diavlo-cord.vercel.app electron ./desktop/main.cjs",
    "desktop:icon": "node scripts/generate-desktop-icon.mjs",
    "desktop:build:dir": "npm run desktop:icon && electron-builder --config electron-builder.json --win --dir",
    "desktop:build:portable": "npm run desktop:icon && electron-builder --config electron-builder.json --win portable",
    "desktop:build": "npm run desktop:icon && electron-builder --config electron-builder.json --win portable nsis",
    "desktop:build:linux:dir": "npm run desktop:icon && electron-builder --config electron-builder.json --linux --dir --x64",
    "desktop:build:linux:appimage": "npm run desktop:icon && electron-builder --config electron-builder.json --linux AppImage --x64",
    "desktop:build:linux": "npm run desktop:build:linux:appimage",
    "desktop:build:arch": "npm run desktop:icon && electron-builder --config electron-builder.json --linux pacman --x64"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.323.0",
    "next": "^16.1.6",
    "react": "^18",
    "react-dom": "^18",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.2.1",
    "uuid": "^9.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
