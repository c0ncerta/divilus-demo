# Server
PORT=3001
# Comma/semicolon/newline separated origins.
# Supports wildcards like: https://*.vercel.app, https://*.onrender.com
CORS_ORIGIN=http://localhost:3000,https://diavlocord.vercel.app
JWT_SECRET=change-me

# Postgres
# DATABASE_URL: Neon pooled (pooler host) is OK for runtime
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# DIRECT_URL: Neon direct (non-pooler) connection recommended for Prisma migrate
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require
